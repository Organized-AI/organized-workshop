# LLM Provider API Keys
# ------------------------------
# NOTE: keep these BLANK in this file. organized-codebase's own .env.example
# (main branch) currently has real-looking values checked in for
# OPENROUTER_API_KEY / GLM_API_KEY -- do not copy those over here.

CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GLM_API_KEY=

# Hybrid Agent Configuration
DEFAULT_LLM_PROVIDER=auto

# Project Configuration
NODE_ENV=development
PROJECT_NAME=organized-workshop

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# GitHub
GITHUB_TOKEN=

# Loop Engineering — Tracker/Notify (see CONFIG/tracker.json, CONFIG/notify.json)
LOOP_TRACKER_SHARED_SECRET=
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
